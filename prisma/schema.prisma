generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantMemberRole {
  member
  admin
  owner
}

enum TenantMemberStatus {
  active
  invited
  disabled
}

enum QuestionType {
  single_choice
  fill_blank
  solution
}

enum QuestionVisibility {
  private
  tenant_shared
}

enum DocumentKind {
  paper
  handout
}

enum DocumentItemType {
  question
  layout_element
}

enum ExportJobStatus {
  pending
  running
  succeeded
  failed
  canceled
}

enum ExportKind {
  document_pdf
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  members   TenantMember[]
}

model Stage {
  id        String   @id @db.Uuid
  tenantId  String?  @db.Uuid
  code      String
  name      String
  order     Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  grades    Grade[]
  questionStages QuestionStage[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
}

model Grade {
  id        String   @id @db.Uuid
  tenantId  String?  @db.Uuid
  stageId   String   @db.Uuid
  code      String
  name      String
  order     Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  stage     Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  questionGrades QuestionGrade[]

  @@index([stageId])
  @@unique([tenantId, stageId, code])
  @@unique([tenantId, stageId, name])
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  username    String   @unique
  passwordHash String
  sessionVersion Int    @default(0)
  createdAt   DateTime @default(now())
  lastLoginAt DateTime?

  memberships TenantMember[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  deliveryMode String   @default("preview")
  previewTail String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TenantMember {
  tenantId  String @db.Uuid
  id        String @default(uuid()) @db.Uuid
  userId    String @db.Uuid
  role      TenantMemberRole @default(member)
  status    TenantMemberStatus @default(active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([tenantId, id])
  @@unique([tenantId, userId])
  @@index([userId])
}

model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([tenantId, name])
}

model Textbook {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  questionTextbooks QuestionTextbook[]

  @@unique([tenantId, name])
}

model Chapter {
  tenantId   String @db.Uuid
  id         String @default(uuid()) @db.Uuid
  textbookId String @db.Uuid
  parentId   String? @db.Uuid
  name       String
  createdAt  DateTime @default(now())

  questionChapters QuestionChapter[]

  @@id([tenantId, id])
  @@index([textbookId])
}

model QuestionTag {
  tenantId   String @db.Uuid
  id         String @default(uuid()) @db.Uuid
  name       String
  createdAt  DateTime @default(now())

  questionTaggings QuestionTagging[]

  @@id([tenantId, id])
  @@unique([tenantId, name])
}

model QuestionTagging {
  tenantId    String @db.Uuid
  questionId  String @db.Uuid
  tagId       String @db.Uuid
  createdAt   DateTime @default(now())

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)
  tag      QuestionTag @relation(fields: [tenantId, tagId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId, tagId])
  @@index([tenantId, tagId])
}

model QuestionStage {
  tenantId   String @db.Uuid
  questionId String @db.Uuid
  stageId    String @db.Uuid
  createdAt  DateTime @default(now())

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)
  stage    Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@id([tenantId, questionId, stageId])
  @@index([tenantId, stageId])
}

model QuestionGrade {
  tenantId   String @db.Uuid
  questionId String @db.Uuid
  gradeId    String @db.Uuid
  createdAt  DateTime @default(now())

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)
  grade    Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@id([tenantId, questionId, gradeId])
  @@index([tenantId, gradeId])
}

model QuestionTextbook {
  tenantId   String @db.Uuid
  questionId String @db.Uuid
  textbookId String @db.Uuid
  createdAt  DateTime @default(now())

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)
  textbook Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@id([tenantId, questionId, textbookId])
  @@index([tenantId, textbookId])
}

model QuestionChapter {
  tenantId   String @db.Uuid
  questionId String @db.Uuid
  chapterId  String @db.Uuid
  createdAt  DateTime @default(now())

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)
  chapter  Chapter  @relation(fields: [tenantId, chapterId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId, chapterId])
  @@index([tenantId, chapterId])
}

model Question {
  tenantId     String @db.Uuid
  id           String @default(uuid()) @db.Uuid
  type         QuestionType
  difficulty   Int
  defaultScore Decimal @db.Decimal(5, 2)
  subjectId    String @db.Uuid
  ownerUserId  String @db.Uuid
  visibility   QuestionVisibility @default(private)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  content       QuestionContent?
  explanation   QuestionExplanation?
  source        QuestionSource?
  choiceAnswer  QuestionAnswerChoice?
  blankAnswer   QuestionAnswerBlank?
  solutionAnswer QuestionAnswerSolution?

  questionTaggings QuestionTagging[]
  questionStages QuestionStage[]
  questionGrades QuestionGrade[]
  questionTextbooks QuestionTextbook[]
  questionChapters QuestionChapter[]

  @@id([tenantId, id])
  @@index([subjectId])
  @@index([ownerUserId])
}

model QuestionContent {
  tenantId    String @db.Uuid
  questionId  String @db.Uuid
  stemBlocks  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId])
}

model QuestionExplanation {
  tenantId        String @db.Uuid
  questionId      String @db.Uuid
  overviewLatex   String?
  overviewBlocks  Json?
  stepsBlocks     Json
  commentaryLatex String?
  commentaryBlocks Json?

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId])
}

model QuestionSource {
  tenantId    String @db.Uuid
  questionId  String @db.Uuid
  year        Int?
  month       Int?
  sourceText  String?

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId])
}

model QuestionAnswerChoice {
  tenantId       String @db.Uuid
  questionId     String @db.Uuid
  optionsBlocks  Json
  correct        Json

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId])
}

model QuestionAnswerBlank {
  tenantId   String @db.Uuid
  questionId String @db.Uuid
  blanks     Json

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId])
}

model QuestionAnswerSolution {
  tenantId         String @db.Uuid
  questionId       String @db.Uuid
  finalAnswerLatex String?
  referenceAnswerBlocks Json?
  scoringPoints    Json
  scoringPointsBlocks Json?

  question Question @relation(fields: [tenantId, questionId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, questionId])
}

model Document {
  tenantId        String @db.Uuid
  id              String @default(uuid()) @db.Uuid
  kind            DocumentKind
  name            String
  createdByUserId String @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items DocumentItem[]

  @@id([tenantId, id])
  @@index([createdByUserId])
}

model LayoutElement {
  tenantId   String @db.Uuid
  id         String @default(uuid()) @db.Uuid
  blocks     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([tenantId, id])
}

model DocumentItem {
  tenantId        String @db.Uuid
  id              String @default(uuid()) @db.Uuid
  documentId      String @db.Uuid
  orderIndex      Int
  itemType        DocumentItemType
  questionId      String? @db.Uuid
  layoutElementId String? @db.Uuid
  scoreOverride   Decimal? @db.Decimal(5, 2)

  document Document @relation(fields: [tenantId, documentId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, id])
  @@index([documentId])
}

model Asset {
  tenantId    String @db.Uuid
  id          String @default(uuid()) @db.Uuid
  kind        String
  originalFilename String?
  storageKey  String
  mime        String
  size        Int
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())

  @@id([tenantId, id])
  @@unique([tenantId, storageKey])
}

model ExportJob {
  tenantId      String @db.Uuid
  id            String @default(uuid()) @db.Uuid
  kind          ExportKind
  documentId    String @db.Uuid
  status        ExportJobStatus @default(pending)
  resultAssetId String? @db.Uuid
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@id([tenantId, id])
  @@index([documentId])
}

model AuditLog {
  tenantId   String @db.Uuid
  id         String @default(uuid()) @db.Uuid
  userId     String? @db.Uuid
  action     String
  targetType String
  targetId   String? @db.Uuid
  details    Json?
  createdAt  DateTime @default(now())

  @@id([tenantId, id])
  @@index([createdAt])
  @@index([action])
  @@index([targetType])
  @@index([userId])
}

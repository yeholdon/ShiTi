{
  "name": "shiti",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "api:start": "node dist/apps/api/main.js",
    "api:dev": "ts-node apps/api/main.ts",
    "worker:start": "node dist/apps/worker/main.js",
    "worker:dev": "ts-node apps/worker/main.ts",
    "start": "npm run api:start",
    "start:dev": "npm run api:dev",
    "start:worker": "npm run worker:start",
    "start:worker:dev": "npm run worker:dev",
    "dev:up": "bash scripts/dev-up.sh",
    "local:up": "bash scripts/local-up.sh",
    "local:up:apps": "bash scripts/local-up-apps.sh",
    "local:down": "bash scripts/local-down.sh",
    "local:restart": "bash scripts/local-restart.sh",
    "local:restart:apps": "bash scripts/local-restart-apps.sh",
    "auth:check-smtp": "bash scripts/check-password-reset-smtp.sh",
    "auth:show-email-events": "bash scripts/show-password-reset-email-events.sh",
    "auth:fetch-email-ops": "bash scripts/fetch-password-reset-email-ops.sh",
    "auth:check-email-ops": "bash scripts/fetch-password-reset-email-ops.sh check",
    "auth:status-email-ops": "bash scripts/fetch-password-reset-email-ops.sh status",
    "auth:metrics-email-ops": "bash scripts/fetch-password-reset-email-ops.sh metrics",
    "auth:write-email-ops-metrics": "bash scripts/write-password-reset-email-ops-metrics.sh",
    "auth:record-email-ops-status": "bash scripts/record-password-reset-email-ops-status.sh",
    "auth:show-email-ops-status-history": "bash scripts/show-password-reset-email-ops-status-history.sh",
    "auth:summarize-email-ops-history": "bash scripts/summarize-password-reset-email-ops-history.sh",
    "auth:alert-email-ops-history": "bash scripts/alert-password-reset-email-ops-history.sh",
    "auth:alert-email-ops-payload": "bash scripts/render-password-reset-email-ops-alert-payload.sh",
    "db:fix-ownership": "bash scripts/fix-db-ownership.sh",
    "lint": "eslint .",
    "format": "prettier -w .",
    "test": "npm run test:all",
    "test:unit": "env -u NODE_OPTIONS jest",
    "test:e2e": "env -u NODE_OPTIONS node test/run-e2e.js",
    "test:all": "npm run test:unit -- --passWithNoTests && npm run test:e2e",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:backfill:block-fields": "ts-node prisma/backfill-block-fields.ts",
    "prisma:studio": "prisma studio",
    "prisma:rls": "ts-node prisma/apply-rls.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.16.1",
    "@types/pdfkit": "^0.17.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "ioredis": "^5.9.3",
    "minio": "^8.0.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "prisma": "^6.16.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^10.0.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "ws": "^8.18.3"
  }
}
